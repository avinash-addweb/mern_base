{
  "name": "@base-mern/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "db:setup": "node scripts/select-schema.js",
    "build": "node scripts/select-schema.js && prisma generate && tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "jest --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/select-schema.js && prisma migrate dev",
    "db:seed": "npx tsx src/prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@base-mern/types": "*",
    "@base-mern/utils": "*",
    "@elastic/elasticsearch": "^9.3.4",
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-seq": "^4.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx src/prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.5.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3"
  }
}
